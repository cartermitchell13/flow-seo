# Webflow OAuth Configuration
WEBFLOW_CLIENT_ID="your-webflow-client-id"
WEBFLOW_CLIENT_SECRET="your-webflow-client-secret"

# Database Configuration
POSTGRES_URL="postgresql://user:password@your-neon-host/database"

# API Key Encryption
# Generate this using node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
ENCRYPTION_KEY="your-32-byte-encryption-key"

# OAuth Callback URLs
OAUTH_CALLBACK_URL="http://localhost:3000/api/auth/callback"
PRODUCTION_OAUTH_CALLBACK_URL="https://your-production-url/api/auth/callback"

# Environment
NODE_ENV="development"

# CORS Configuration
ALLOWED_ORIGINS=http://localhost:1337
